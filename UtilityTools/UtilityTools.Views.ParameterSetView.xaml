<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="UtilityTools.Views.ParameterSetView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:w32="clr-namespace:Microsoft.Win32;assembly=PresentationFramework" xmlns:View="clr-namespace:UtilityTools.Views" xmlns:ViewModel="clr-namespace:UtilityTools.ViewModels">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <BooleanToVisibilityConverter x:Key="BoolToVis" />
      <sys:String x:Key="dots">......................................................................................................................................................................................................</sys:String>
      <DataTemplate x:Key="IntParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" />
          <TextBox HorizontalAlignment="Stretch" DockPanel.Dock="Right" MinWidth="30" VerticalAlignment="Bottom" Text="{Binding IntValue, UpdateSourceTrigger=Explicit}" ToolTip="{Binding ToolTip}" PreviewKeyDown="ValueTextBox_PreviewKeyDown" LostFocus="ValueControl_LostFocus" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="FloatParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" />
          <TextBox HorizontalAlignment="Stretch" DockPanel.Dock="Right" MinWidth="60" VerticalAlignment="Bottom" Text="{Binding FloatValue, UpdateSourceTrigger=Explicit}" ToolTip="{Binding ToolTip}" PreviewKeyDown="ValueTextBox_PreviewKeyDown" LostFocus="ValueControl_LostFocus" />
          <Slider Width="100" DockPanel.Dock="Right" Value="{Binding FloatValue, UpdateSourceTrigger=Explicit}" Maximum="{Binding FloatMax}" Minimum="{Binding FloatMin}" LargeChange="{Binding LargeChange}" SmallChange="{Binding SmallChange}" LostFocus="ValueControl_LostFocus" ValueChanged="Slider_ValueChanged" Thumb.DragStarted="Slider_DragStarted" Thumb.DragCompleted="Slider_DragCompleted" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="BoolParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <CheckBox VerticalAlignment="Center" DockPanel.Dock="Right" IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="RGBParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <Border Name="rgbBorder" BorderThickness="2" BorderBrush="#FF000000" DockPanel.Dock="Right">
            <Button Width="16" Height="16" Margin="2" Command="{Binding SelectColorCommand}">
              <Control.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                  <Grid>
                    <Rectangle Width="16" Height="16" Fill="{Binding RGBValue}" />
                    <ContentPresenter />
                  </Grid>
                </ControlTemplate>
              </Control.Template>
            </Button>
          </Border>
          <TextBox Width="30" DockPanel.Dock="Right" Text="{Binding BValue}" />
          <TextBlock Text="B &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
          <TextBox Width="30" DockPanel.Dock="Right" Text="{Binding GValue}" />
          <TextBlock Text="G &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
          <TextBox Width="30" DockPanel.Dock="Right" Text="{Binding RValue}" />
          <TextBlock Text="R &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="EnumParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <ComboBox MinWidth="150" DockPanel.Dock="Right" ItemsSource="{Binding Enumerations}" SelectedValue="{Binding StringValue}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="StringParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <TextBox MinWidth="150" DockPanel.Dock="Right" Text="{Binding StringValue}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="ObjectParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <Button Content="X" Height="22" DockPanel.Dock="Right" ToolTip="Clear Parameter" Tag="{Binding}" Command="{Binding ClearObjectParameterCommand}" CommandParameter="{Binding}" />
          <ToggleButton Content="Hide" DockPanel.Dock="Right" Margin="2 0" ToolTip="Switches the parameter to the default object for previewing." IsChecked="{Binding UseDefaultParameter}" />
          <Button Height="22" DockPanel.Dock="Right" ToolTip="Reimport" Visibility="{Binding ImportableEntitySelected, Converter={StaticResource BoolToVis}}" Command="{Binding ReimportEntityCommand}" CommandParameter="{Binding}">
            <Image Source="/Resources/Import.png" Width="16" Height="16" />
          </Button>
          <Button Height="22" DockPanel.Dock="Right" ToolTip="Open Source File(s)" Visibility="{Binding ImportableEntitySelected, Converter={StaticResource BoolToVis}}" Command="{Binding OpenSourceFileCommand}" CommandParameter="{Binding}">
            <Image Source="/Resources/Preview.png" Width="16" Height="16" />
          </Button>
          <Button Content="Browse..." Height="22" DockPanel.Dock="Right" ToolTip="Add entity from the Cloud" Command="{Binding SetParameterCommand}" />
          <Button Content="New" Height="22" DockPanel.Dock="Right" ToolTip="Add new entity from Source File" Command="{Binding NewParameterCommand}" />
          <TextBox Background="#FF707070" Foreground="#FFFFFFFF" Height="22" BorderThickness="0" IsReadOnly="True" MinWidth="60" DockPanel.Dock="Right" Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{Binding ObjectValue, Mode=OneWay}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="MaterialParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock DockPanel.Dock="Left" VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <Button Content="X" Height="22" DockPanel.Dock="Right" Tag="{Binding}" Command="{Binding ClearObjectParameterCommand}" CommandParameter="{Binding}" />
          <ToggleButton Content="Hide" DockPanel.Dock="Right" Margin="2 0" ToolTip="Switches the parameter to the default object for previewing." IsChecked="{Binding UseDefaultParameter}" />
          <Button Height="22" DockPanel.Dock="Right" ToolTip="Reimport" Visibility="{Binding ImportableEntitySelected, Converter={StaticResource BoolToVis}}" Command="{Binding ReimportEntityCommand}" CommandParameter="{Binding}">
            <Image Source="/Resources/Import.png" Width="16" Height="16" />
          </Button>
          <Button Height="22" DockPanel.Dock="Right" ToolTip="Open Source File(s)" Visibility="{Binding ImportableEntitySelected, Converter={StaticResource BoolToVis}}" Command="{Binding OpenSourceFileCommand}" CommandParameter="{Binding}">
            <Image Source="/Resources/Preview.png" Width="16" Height="16" />
          </Button>
          <Button Content="Browse..." Height="22" DockPanel.Dock="Right" Command="{Binding SetParameterCommand}" />
          <ComboBox Height="22" DockPanel.Dock="Right" ToolTip="Contains valid materials for this slot." ItemsSource="{Binding MaterialNames}" SelectedValue="{Binding SelectedMaterialName}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="OtherParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <TextBlock Text="This is an Unknown Parameter" VerticalAlignment="Bottom" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="CollectionParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock VerticalAlignment="Bottom" Text="{Binding Name}" ToolTip="{Binding ToolTip}" />
          <ItemsControl VerticalAlignment="Stretch" DockPanel.Dock="Top" HorizontalAlignment="Stretch" ItemTemplateSelector="{DynamicResource ParameterSetItemTemplateSelector}" ItemsSource="{Binding Items}" />
        </DockPanel>
      </DataTemplate>
      <View:ParameterSetItemTemplateSelector x:Key="ParameterSetItemTemplateSelector" IntParameterContentTemplate="{StaticResource IntParameterContentTemplate}" FloatParameterContentTemplate="{StaticResource FloatParameterContentTemplate}" BoolParameterContentTemplate="{StaticResource BoolParameterContentTemplate}" RGBParameterContentTemplate="{StaticResource RGBParameterContentTemplate}" StringParameterContentTemplate="{StaticResource StringParameterContentTemplate}" EnumParameterContentTemplate="{StaticResource EnumParameterContentTemplate}" ObjectParameterContentTemplate="{StaticResource ObjectParameterContentTemplate}" MaterialParameterContentTemplate="{StaticResource MaterialParameterContentTemplate}" CollectionParameterContentTemplate="{StaticResource CollectionParameterContentTemplate}" OtherParameterContentTemplate="{StaticResource OtherParameterContentTemplate}" />
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <ItemsControl VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ItemTemplateSelector="{StaticResource ParameterSetItemTemplateSelector}" ItemsSource="{Binding ParameterList}" />
</UserControl>