<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="UtilityTools.Views.KnobViews.RangeKnobView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:knobviews="clr-namespace:UtilityTools.Views.KnobViews;assembly=UtilityTools">
  <DockPanel>
    <Label DockPanel.Dock="Left" Margin="0 0 5 0" Content="{Binding Label}" />
    <TextBox Name="valueTextbox" DockPanel.Dock="Left" MinWidth="40" MaxWidth="40" IsEnabled="{Binding IsEnabled}" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding ToolTip}" />
    <Slider Name="valueSlider" MinWidth="40" IsEnabled="{Binding IsEnabled}" Minimum="{Binding MinValue}" Maximum="{Binding MaxValue}" Value="{Binding Value}" ToolTip="{Binding ToolTip}" />
  </DockPanel>
</UserControl>