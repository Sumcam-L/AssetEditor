<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="UtilityTools.Helpers.PromptForStringDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="String Dialog" Height="125" Width="380" WindowStartupLocation="CenterScreen" xmlns:helpers="clr-namespace:UtilityTools.Helpers;assembly=UtilityTools">
  <Grid>
    <TextBlock Name="TextMessage" Margin="10 10 10 0" Text="" />
    <TextBox Name="TxtBox" Height="23" Margin="10,35,10,0" Width="Auto" TextWrapping="Wrap" VerticalAlignment="Top" Text="{Binding userString}" FocusManager.FocusedElement="{Binding ElementName=TxtBox}" TextChanged="OnTextChanged" />
    <Button Content="Cancel" HorizontalAlignment="Right" Margin="0,63,10,0" VerticalAlignment="Top" Width="75" Click="OnOKButtonClick" />
    <Button Content="OK" HorizontalAlignment="Right" Margin="0,63,95,0" VerticalAlignment="Top" Width="75" IsDefault="True" Click="OnOKButtonClick" />
  </Grid>
</Window>