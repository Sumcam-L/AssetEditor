<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="UtilityTools.Views.StringListPreviewerKnobView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:views="clr-namespace:UtilityTools.Views;assembly=UtilityTools">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <sys:String x:Key="dots">......................................................................................................................................................................................................</sys:String>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <DockPanel LastChildFill="True">
    <Label Name="label" DockPanel.Dock="Left" Margin="0 0 5 0" Content="{Binding Label}" />
    <ComboBox Name="items" DockPanel.Dock="Right" ItemsSource="{Binding AvailableItems}" SelectedItem="{Binding SelectedItem}" />
    <TextBlock Text="{StaticResource dots}" Margin="4,0,4,0" VerticalAlignment="Bottom" />
  </DockPanel>
</UserControl>