<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="UtilityTools.Views.KnobViews.KnobSetView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:KnobViews="clr-namespace:UtilityTools.Views.KnobViews" xmlns:UtilConverters="clr-namespace:Firaxis.Utility.Converters;assembly=Firaxis.Utility">
  <DockPanel>
    <FrameworkElement.Resources>
      <ResourceDictionary>
        <BooleanToVisibilityConverter x:Key="boolToVis" />
        <UtilConverters:InverseBoolToVis x:Key="inverseBoolToVis" />
        <sys:String x:Key="dots">......................................................................................................................................................................................................</sys:String>
        <DataTemplate x:Key="standardValueTemplate">
          <DockPanel LastChildFill="True">
            <DockPanel>
              <Label Name="label" Margin="0 0 5 0" DockPanel.Dock="Left" VerticalAlignment="Center" Content="{Binding Label}" />
              <TextBox Name="valueTextbox" DockPanel.Dock="Left" VerticalAlignment="Center" Text="{Binding Value}" ToolTip="{Binding ToolTip}" Visibility="{Binding IsEnabled, Converter={StaticResource boolToVis}}" />
              <TextBlock Name="valueText" DockPanel.Dock="Left" VerticalAlignment="Center" FontStyle="Italic" MaxWidth="100" TextWrapping="WrapWithOverflow" Text="{Binding Value}" ToolTip="{Binding ToolTip}" Visibility="{Binding IsEnabled, Converter={StaticResource inverseBoolToVis}}" />
            </DockPanel>
          </DockPanel>
        </DataTemplate>
        <DataTemplate x:Key="boolValueTemplate">
          <DockPanel LastChildFill="True">
            <DockPanel>
              <Label Name="label" Margin="0 0 5 0" DockPanel.Dock="Left" Content="{Binding Label}" />
              <CheckBox Name="valueCheckbox" DockPanel.Dock="Left" VerticalAlignment="Center" IsChecked="{Binding Value}" ToolTip="{Binding ToolTip}" IsEnabled="{Binding IsEnabled}" />
            </DockPanel>
          </DockPanel>
        </DataTemplate>
        <DataTemplate x:Key="colorValueTemplate">
          <DockPanel LastChildFill="True">
            <Label Name="label" Margin="0 0 5 0" DockPanel.Dock="Left" Content="{Binding Label}" />
            <Border Name="rgbBorder" BorderThickness="2" BorderBrush="#FF000000">
              <Button Width="16" Height="16" Margin="2" Command="{Binding SelectColorCommand}" ToolTip="{Binding ToolTip}" IsEnabled="{Binding IsEnabled}">
                <Control.Template>
                  <ControlTemplate TargetType="{x:Type Button}">
                    <Grid>
                      <Rectangle Width="16" Height="16" Fill="{Binding ValueBrush}" />
                      <ContentPresenter />
                    </Grid>
                  </ControlTemplate>
                </Control.Template>
              </Button>
            </Border>
            <TextBox Name="BlueText" Width="30" DockPanel.Dock="Right" Text="{Binding BValue}" />
            <TextBlock Text="B &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
            <TextBox Name="GreenText" Width="30" DockPanel.Dock="Right" Text="{Binding GValue}" />
            <TextBlock Text="G &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
            <TextBox Name="RedText" Width="30" DockPanel.Dock="Right" Text="{Binding RValue}" />
            <TextBlock Text="R &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
            <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
          </DockPanel>
        </DataTemplate>
        <DataTemplate x:Key="functionTemplate">
          <DockPanel>
            <KnobViews:FunctionKnobView HorizontalAlignment="Left" VerticalAlignment="Stretch" />
          </DockPanel>
        </DataTemplate>
        <DataTemplate x:Key="rangeTemplate">
          <DockPanel>
            <KnobViews:RangeKnobView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
          </DockPanel>
        </DataTemplate>
        <DataTemplate x:Key="containerTemplate">
          <DockPanel>
            <KnobViews:ContainerKnobView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
          </DockPanel>
        </DataTemplate>
        <KnobViews:KnobTemplateSelector x:Key="KnobTemplateSelecor" ValueContentTemplate="{StaticResource standardValueTemplate}" BoolValueContentTemplate="{StaticResource boolValueTemplate}" ColorContentTemplate="{StaticResource colorValueTemplate}" FunctionKnobContentTemplate="{StaticResource functionTemplate}" RangeKnobContentTemplate="{StaticResource rangeTemplate}" ContainerKnobContentTemplate="{StaticResource containerTemplate}" />
      </ResourceDictionary>
    </FrameworkElement.Resources>
    <Expander>
      <HeaderedContentControl.Header>
        <Label Name="groupLabel" FontWeight="SemiBold" FontSize="14" Content="{Binding KnobSetDisplayName}" />
      </HeaderedContentControl.Header>
      <ContentControl.Content>
        <DockPanel>
          <ItemsControl VerticalAlignment="Stretch" DockPanel.Dock="Top" HorizontalAlignment="Stretch" ItemTemplateSelector="{StaticResource KnobTemplateSelecor}" ItemsSource="{Binding Knobs}" />
          <ItemsControl VerticalAlignment="Stretch" DockPanel.Dock="Top" HorizontalAlignment="Stretch" ItemsSource="{Binding KnobSubgroups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Expander Margin="5 0 0 0">
                  <HeaderedContentControl.Header>
                    <Label FontWeight="SemiBold" FontSize="14" Content="{Binding Key}" />
                  </HeaderedContentControl.Header>
                  <ContentControl.Content>
                    <ItemsControl VerticalAlignment="Stretch" DockPanel.Dock="Top" HorizontalAlignment="Stretch" ItemTemplateSelector="{StaticResource KnobTemplateSelecor}" ItemsSource="{Binding Value}" />
                  </ContentControl.Content>
                </Expander>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </ContentControl.Content>
    </Expander>
  </DockPanel>
</UserControl>