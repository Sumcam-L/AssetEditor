<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="UtilityTools.Views.ParameterKnobView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:w32="clr-namespace:Microsoft.Win32;assembly=PresentationFramework" xmlns:View="clr-namespace:UtilityTools.Views" xmlns:ViewModel="clr-namespace:UtilityTools.ViewModels">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <sys:String x:Key="dots">......................................................................................................................................................................................................</sys:String>
      <DataTemplate x:Key="IntParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBox HorizontalAlignment="Stretch" DockPanel.Dock="Right" MinWidth="30" VerticalAlignment="Bottom" Text="{Binding IntValue, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="FloatParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBox HorizontalAlignment="Stretch" DockPanel.Dock="Right" Width="60" VerticalAlignment="Bottom" Text="{Binding FloatValue, UpdateSourceTrigger=PropertyChanged}" />
          <Slider Width="100" DockPanel.Dock="Right" Value="{Binding FloatValue, UpdateSourceTrigger=PropertyChanged}" Maximum="{Binding FloatMax}" Minimum="{Binding FloatMin}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="BoolParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <CheckBox VerticalAlignment="Center" DockPanel.Dock="Right" IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="RGBParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <Border BorderThickness="2" BorderBrush="#FF000000">
            <Rectangle DockPanel.Dock="Right" Width="16" Height="16" Margin="2" Fill="{Binding RGBColor}" MouseDown="RGB_Rectangle_MouseDown" />
          </Border>
          <TextBox Name="BlueText" Width="30" DockPanel.Dock="Right" Text="{Binding BValue}" />
          <TextBlock Text="B &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
          <TextBox Name="GreenText" Width="30" DockPanel.Dock="Right" Text="{Binding GValue}" />
          <TextBlock Text="G &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
          <TextBox Name="RedText" Width="30" DockPanel.Dock="Right" Text="{Binding RValue}" />
          <TextBlock Text="R &gt;" DockPanel.Dock="Right" VerticalAlignment="Bottom" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="StringParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <ComboBox MinWidth="150" DockPanel.Dock="Right" ItemsSource="{Binding Enumerations}" SelectedValue="{Binding StringValue}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="ObjectParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <Button Content="X" Height="22" DockPanel.Dock="Right" Tag="{Binding}" Command="{Binding ClearObjectParameterCommand}" CommandParameter="{Binding}" />
          <Button Content="Browse..." Height="22" DockPanel.Dock="Right" Command="{Binding SetParameterCommand}" />
          <TextBox Background="#FF707070" Foreground="#FFFFFFFF" Height="22" BorderThickness="0" IsReadOnly="True" MinWidth="60" DockPanel.Dock="Right" Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{Binding ObjectValue, Mode=OneWay}" />
          <TextBlock Margin="4,0,4,0" VerticalAlignment="Bottom" Text="{StaticResource dots}" />
        </DockPanel>
      </DataTemplate>
      <DataTemplate x:Key="OtherParameterContentTemplate">
        <DockPanel LastChildFill="True" MinHeight="22" Margin="2">
          <TextBlock VerticalAlignment="Bottom" Text="{Binding Name}" />
          <TextBlock Text="This is an Unknown Parameter" VerticalAlignment="Bottom" />
        </DockPanel>
      </DataTemplate>
      <View:ParameterSetItemTemplateSelector x:Key="ParameterSetItemTemplateSelector" IntParameterContentTemplate="{StaticResource IntParameterContentTemplate}" FloatParameterContentTemplate="{StaticResource FloatParameterContentTemplate}" BoolParameterContentTemplate="{StaticResource BoolParameterContentTemplate}" RGBParameterContentTemplate="{StaticResource RGBParameterContentTemplate}" StringParameterContentTemplate="{StaticResource StringParameterContentTemplate}" ObjectParameterContentTemplate="{StaticResource ObjectParameterContentTemplate}" OtherParameterContentTemplate="{StaticResource OtherParameterContentTemplate}" />
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <DockPanel LastChildFill="True">
    <Label Name="label" Margin="0 0 5 0" Content="{Binding Label}" />
    <ContentControl Name="parameter" ContentTemplateSelector="{StaticResource ParameterSetItemTemplateSelector}" Content="{Binding ParameterVM}" />
  </DockPanel>
</UserControl>