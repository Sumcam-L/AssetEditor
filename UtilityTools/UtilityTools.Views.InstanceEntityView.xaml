<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="UtilityTools.Views.InstanceEntityView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:UtilViews="clr-namespace:UtilityTools.Views" xmlns:UtilViewModels="clr-namespace:UtilityTools.ViewModels" Width="Auto">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <BooleanToVisibilityConverter x:Key="BoolToVis" />
      <Color x:Key="LightGrayBackgroundColor">#FF858585</Color>
      <Color x:Key="GrayBackgroundColor">#FF707070</Color>
      <Color x:Key="DarkGrayColor">#FF464646</Color>
      <Color x:Key="DarkGrayColorTwo">#FF4C4C4C</Color>
      <Color x:Key="WhiteTextColor">#FFFFFFFF</Color>
      <SolidColorBrush x:Key="LightGrayBackgroundBrush" Color="{StaticResource LightGrayBackgroundColor}" />
      <SolidColorBrush x:Key="GrayBackgroundBrush" Color="{StaticResource GrayBackgroundColor}" />
      <SolidColorBrush x:Key="DarkGrayBrush" Color="{StaticResource DarkGrayColor}" />
      <SolidColorBrush x:Key="ExpanderBackgroundBrush" Color="{StaticResource DarkGrayColorTwo}" />
      <SolidColorBrush x:Key="WhiteTextBrush" Color="{StaticResource WhiteTextColor}" />
      <Style x:Key="BaseLabelStyle" TargetType="{x:Type Label}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinWidth" Value="50" />
        <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}" />
      </Style>
      <DataTemplate x:Key="ParameterSetContentTemplate">
        <UtilViews:ParameterSetView VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
      </DataTemplate>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#FFF5F5DC" DockPanel.Dock="Top">
    <DockPanel Background="#FF707070">
      <StackPanel HorizontalAlignment="Stretch" Margin="5" VerticalAlignment="Top" DockPanel.Dock="Top">
        <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
          <Label Content="Class:" Style="{StaticResource BaseLabelStyle}" />
          <ComboBox Margin="10 0" ItemsSource="{Binding AvailableClasses}" SelectedValue="{Binding ClassName}" IsEnabled="{Binding NewInstanceEntity}" />
        </DockPanel>
        <StackPanel Visibility="{Binding HasClass, Converter={StaticResource BoolToVis}}">
          <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
            <Label Content="Tags:" Style="{StaticResource BaseLabelStyle}" />
            <Label Content="{Binding TagsAsString}" />
          </DockPanel>
          <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
            <Button Content="Add Tag" DockPanel.Dock="Right" Command="{Binding AddTagCommand}" />
            <TextBox Name="TagTextBox" Text="{Binding TagToAdd}" />
          </DockPanel>
          <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
            <Label Content="Description:" Style="{StaticResource BaseLabelStyle}" />
            <TextBox Margin="5" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
          <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">
            <Expander Background="{StaticResource ExpanderBackgroundBrush}" Foreground="{StaticResource WhiteTextBrush}" Margin="0 6 0 0" IsExpanded="True">
              <HeaderedContentControl.Header>
                <DockPanel LastChildFill="False">
                  <TextBlock FontWeight="Bold" Text="Parameters:" DockPanel.Dock="Left" VerticalAlignment="Center" />
                  <Button Content="New from File" Padding="5 0 5 0" Margin="5 0 5 0" DockPanel.Dock="Left" VerticalAlignment="Center" Visibility="{Binding IsMaterial, Converter={StaticResource BoolToVis}}" Command="{Binding NewFromFileCommand}" />
                </DockPanel>
              </HeaderedContentControl.Header>
              <ContentControl.Content>
                <UtilViews:ParameterSetView ContentTemplate="{StaticResource ParameterSetContentTemplate}" Content="{Binding ParametersViewModel}" />
              </ContentControl.Content>
            </Expander>
          </DockPanel>
        </StackPanel>
      </StackPanel>
      <StackPanel DockPanel.Dock="Bottom" Background="{StaticResource GrayBackgroundBrush}" Orientation="Horizontal" MinWidth="185" Height="30" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
        <Button Content="Reimport" Margin="0 0 5 0" Command="{Binding ReimportCommand}" CommandParameter="{Binding}" Visibility="{Binding ReimportVisible, Converter={StaticResource BoolToVis}}" />
        <Button Content="Save" Margin="0 0 5 0" Command="{Binding SaveCommand}" />
        <Button Content="Save As..." Margin="0 0 5 0" Command="{Binding SaveAsCommand}" />
        <Button Content="Cancel" Margin="0 0 5 0" Command="{Binding CancelCommand}" />
      </StackPanel>
    </DockPanel>
  </ScrollViewer>
</UserControl>