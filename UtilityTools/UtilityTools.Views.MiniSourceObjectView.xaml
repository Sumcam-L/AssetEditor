<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="UtilityTools.Views.MiniSourceObjectView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:UtilConverters="clr-namespace:Firaxis.Utility.Converters;assembly=Firaxis.Utility" Margin="0 0 0 5" Width="Auto" xmlns:views="clr-namespace:UtilityTools.Views;assembly=UtilityTools">
  <DockPanel LastChildFill="True" IsEnabled="{Binding SelectionEnabled}">
    <FrameworkElement.Resources>
      <ResourceDictionary>
        <Color x:Key="LightGrayBackgroundColor">#FF858585</Color>
        <Color x:Key="GrayBackgroundColor">#FF707070</Color>
        <Color x:Key="DarkGrayColor">#FF464646</Color>
        <Color x:Key="DarkGrayColorTwo">#FF4C4C4C</Color>
        <Color x:Key="WhiteTextColor">#FFFFFFFF</Color>
        <SolidColorBrush x:Key="LightGrayBackgroundBrush" Color="{StaticResource LightGrayBackgroundColor}" />
        <SolidColorBrush x:Key="GrayBackgroundBrush" Color="{StaticResource GrayBackgroundColor}" />
        <SolidColorBrush x:Key="DarkGrayBrush" Color="{StaticResource DarkGrayColor}" />
        <SolidColorBrush x:Key="ExpanderBackgroundBrush" Color="{StaticResource DarkGrayColorTwo}" />
        <SolidColorBrush x:Key="WhiteTextBrush" Color="{StaticResource WhiteTextColor}" />
        <Style x:Key="BaseLabelStyle" TargetType="{x:Type Label}">
          <Setter Property="HorizontalAlignment" Value="Left" />
          <Setter Property="Margin" Value="0" />
          <Setter Property="MinWidth" Value="50" />
          <Setter Property="Foreground" Value="{StaticResource WhiteTextBrush}" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <UtilConverters:InverseBooleanConverter x:Key="inverseBoolConverter" />
      </ResourceDictionary>
    </FrameworkElement.Resources>
    <CheckBox Name="nameText" DockPanel.Dock="Left" Foreground="{StaticResource WhiteTextBrush}" VerticalAlignment="Center" Margin="3 0 1 0" ToolTip="{Binding Name}" IsChecked="{Binding IsSelected}" />
    <TextBlock Name="existingClassName" DockPanel.Dock="Right" Margin="0 0 5 0" Foreground="#FFFF0000" FontStyle="Italic" VerticalAlignment="Center" HorizontalAlignment="Right" ToolTip="Currently assigned class.  Please rename the entity to continue with the import." Text="{Binding ClassName}" Visibility="{Binding HasInvalidClass, Converter={StaticResource BoolToVis}}" />
    <ComboBox Name="classesCombobox" Width="140" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0 0 5 0" ItemsSource="{Binding AllowedEntityClasses}" SelectedItem="{Binding SelectedEntityClass}" IsEnabled="{Binding EntityAlreadyExists, Converter={StaticResource inverseBoolConverter}}" />
    <CheckBox Name="overwriteBox" DockPanel.Dock="Right" Content="Overwrite" Margin="0 0 5 0" Foreground="#FFFFFF" VerticalAlignment="Center" TextBlock.Foreground="#FFFFFF" ToolTip="This entity already exists. Check this overwrite it or change the name." IsEnabled="{Binding OverwriteEnabled}" Visibility="{Binding EntityAlreadyExists, Converter={StaticResource BoolToVis}}" IsChecked="{Binding OverwriteSelected}" />
    <TextBox DockPanel.Dock="Left" MinWidth="160" Margin="5 0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
  </DockPanel>
</UserControl>