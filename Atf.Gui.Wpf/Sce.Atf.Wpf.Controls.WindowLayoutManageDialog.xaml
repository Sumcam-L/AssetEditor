<?xml version="1.0" encoding="utf-8"?>
<lc:CommonDialog x:Class="Sce.Atf.Wpf.Controls.WindowLayoutManageDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:l="clr-namespace:Sce.Atf.Wpf" xmlns:m="clr-namespace:Sce.Atf.Wpf.Markup" xmlns:lc="clr-namespace:Sce.Atf.Wpf.Controls" xmlns:b="clr-namespace:Sce.Atf.Wpf.Behaviors" xmlns:c="clr-namespace:Sce.Atf.Wpf.ValueConverters" Width="650" Height="400" ShowInTaskbar="False" MinWidth="250">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <l:CommandReference x:Key="RenameCommandRef" Command="{Binding RenameCommand}" />
      <l:CommandReference x:Key="DeleteCommandRef" Command="{Binding DeleteCommand}" />
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <UIElement.InputBindings>
    <KeyBinding Key="F2" Command="{StaticResource RenameCommandRef}" />
    <KeyBinding Key="Delete" Command="{StaticResource DeleteCommandRef}" />
  </UIElement.InputBindings>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ListView IsSynchronizedWithCurrentItem="True" ItemsSource="{Binding LayoutView}">
      <FrameworkElement.Resources>
        <ResourceDictionary>
          <Style x:Key="EditableTextBox" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Style.Triggers>
              <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="FrameworkElement.ToolTip" Value="{Binding RelativeSource={x:Static RelativeSource.Self}, Path=(Validation.Errors)[0].ErrorContent}" />
              </Trigger>
            </Style.Triggers>
            <Setter Property="b:ThemeStyleBehavior.AutoMergeStyle" Value="True" />
            <Setter Property="b:EditableTextBlockBehavior.IsInEditMode" Value="{Binding IsInEditMode, Mode=TwoWay}" />
          </Style>
        </ResourceDictionary>
      </FrameworkElement.Resources>
      <ItemsControl.ItemContainerStyle>
        <Style BasedOn="{StaticResource {x:Static GridView.GridViewItemContainerStyleKey}}" TargetType="{x:Type ListViewItem}">
          <Style.Resources>
            <ResourceDictionary>
              <ContextMenu x:Key="ContextMenu">
                <MenuItem Command="{Binding DeleteCommand}" Header="{m:Loc Delete}" />
                <MenuItem Command="{Binding RenameCommand}" Header="{m:Loc Rename}" />
              </ContextMenu>
            </ResourceDictionary>
          </Style.Resources>
          <Setter Property="b:ThemeStyleBehavior.AutoMergeStyle" Value="True" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="FrameworkElement.ContextMenu" Value="{StaticResource ContextMenu}" />
        </Style>
      </ItemsControl.ItemContainerStyle>
      <ListView.View>
        <GridView>
          <GridViewColumn Width="150" Header="{m:Loc Layout Name}">
            <GridViewColumn.CellTemplate>
              <DataTemplate>
                <TextBlock HorizontalAlignment="Stretch" Style="{DynamicResource EditableTextBox}" Text="{Binding Name, Mode=TwoWay, ValidatesOnExceptions=True, ValidatesOnDataErrors=True}" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
          <GridViewColumn Width="100" Header="{m:Loc Shortcut}" DisplayMemberBinding="{Binding Shortcut, Converter={c:InputGestureTextConverter}}" />
        </GridView>
      </ListView.View>
    </ListView>
    <GridSplitter Grid.Column="1" Width="3" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
    <Border Grid.Column="2" BorderThickness="1" Padding="4" BorderBrush="{x:Static SystemColors.ControlDarkBrush}">
      <ContentControl>
        <Viewbox>
          <Image Source="{Binding LayoutView.CurrentItem.Image}" />
        </Viewbox>
      </ContentControl>
    </Border>
    <DockPanel Grid.Row="1" Grid.ColumnSpan="3" LastChildFill="False" Margin="0,12,0,0">
      <Button Margin="0" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Command="{Binding DeleteCommand}" Content="{m:Loc Delete}" />
      <Button Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Command="{Binding RenameCommand}" Content="{m:Loc Rename}" />
      <Button DockPanel.Dock="Right" IsDefault="True" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Command="{Binding OkCommand}" Content="{m:Loc OK}" />
    </DockPanel>
  </Grid>
</lc:CommonDialog>