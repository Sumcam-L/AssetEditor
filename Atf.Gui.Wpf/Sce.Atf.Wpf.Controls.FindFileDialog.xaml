<?xml version="1.0" encoding="utf-8"?>
<c:CommonDialog x:Class="Sce.Atf.Wpf.Controls.FindFileDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:l="clr-namespace:Sce.Atf.Wpf" xmlns:m="clr-namespace:Sce.Atf.Wpf.Markup" xmlns:c="clr-namespace:Sce.Atf.Wpf.Controls" xmlns:vc="clr-namespace:Sce.Atf.Wpf.ValueConverters" ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height" Width="400">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="{x:Type TextBox}" TargetType="{x:Type TextBox}">
        <Style.Triggers>
          <Trigger Property="TextBoxBase.IsReadOnly" Value="True">
            <Setter Property="Background" Value="#00FFFFFF" />
          </Trigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <StackPanel>
    <StackPanel>
      <TextBlock Text="{m:Loc The following file could not be found at the specified location:}" />
      <TextBox TextWrapping="Wrap" IsReadOnly="True" Background="#00FFFFFF" BorderThickness="0" Margin="16,8,16,12" Text="{Binding OriginalPath}" />
    </StackPanel>
    <StackPanel Visibility="{Binding SuggestedPath, Converter={vc:ItemNullToVisibilityConverter}}">
      <TextBlock Text="{m:Loc The file was found here:}" />
      <TextBox TextWrapping="Wrap" IsReadOnly="True" Background="#00FFFFFF" BorderThickness="0" Margin="16,8,16,0" Text="{Binding SuggestedPath}" />
    </StackPanel>
    <Separator Margin="0,12,0,12" />
    <StackPanel>
      <TextBlock Text="{m:Loc What would you like to do?}" />
      <ListBox Style="{StaticResource {x:Static l:Resources.RadioButtonListStyleKey}}" Margin="16,8,16,0" SelectedValuePath="Content" SelectedValue="{Binding Action}">
        <FrameworkElement.Resources>
          <ResourceDictionary>
            <DataTemplate x:Key="{DataTemplateKey {x:Type l:FindFileAction}}" DataType="{x:Type l:FindFileAction}">
              <TextBlock Text="{Binding Converter={vc:DisplayStringConverter}}" />
            </DataTemplate>
          </ResourceDictionary>
        </FrameworkElement.Resources>
        <ListBoxItem Content="{x:Static l:FindFileAction.AcceptSuggestion}" Visibility="{Binding SuggestedPath, Converter={vc:ItemNullToVisibilityConverter}}" />
        <ListBoxItem Content="{x:Static l:FindFileAction.AcceptAllSuggestions}" Visibility="{Binding SuggestedPath, Converter={vc:ItemNullToVisibilityConverter}}" />
        <ListBoxItem Content="{x:Static l:FindFileAction.UserSpecify}" />
        <ListBoxItem Content="{x:Static l:FindFileAction.SearchDirectory}" />
        <ListBoxItem Content="{x:Static l:FindFileAction.SearchDirectoryForAll}" />
        <ListBoxItem Content="{x:Static l:FindFileAction.Ignore}" />
        <ListBoxItem Content="{x:Static l:FindFileAction.IgnoreAll}" />
      </ListBox>
    </StackPanel>
    <Separator Margin="0,12,0,12" />
    <TextBlock VerticalAlignment="Top" TextWrapping="Wrap" Margin="0,0,0,12" Text="{Binding Action, Converter={vc:EnumDescriptionConverter}}" />
    <DockPanel LastChildFill="False">
      <Button DockPanel.Dock="Right" IsCancel="True" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Command="{Binding CancelCommand}" Content="{m:Loc Cancel}" />
      <Button DockPanel.Dock="Right" IsDefault="True" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Command="{Binding OkCommand}" Content="{m:Loc OK}" />
    </DockPanel>
  </StackPanel>
</c:CommonDialog>