<?xml version="1.0" encoding="utf-8"?>
<ct:CommonDialog x:Class="Sce.Atf.Wpf.Controls.TcpIpTargetEditDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:l="clr-namespace:Sce.Atf.Wpf" xmlns:ct="clr-namespace:Sce.Atf.Wpf.Controls" xmlns:m="clr-namespace:Sce.Atf.Wpf.Markup" xmlns:b="clr-namespace:Sce.Atf.Wpf.Behaviors" ResizeMode="NoResize" SizeToContent="WidthAndHeight">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="rightStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="b:ThemeStyleBehavior.AutoMergeStyle" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="Grid.Column" Value="1" />
      </Style>
      <Style x:Key="leftStyle" TargetType="{x:Type Label}" BasedOn="{StaticResource {x:Type Label}}">
        <Setter Property="b:ThemeStyleBehavior.AutoMergeStyle" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Grid.Column" Value="0" />
        <Setter Property="Margin" Value="0,0,0,4" />
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid HorizontalAlignment="Center">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="120" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Label Style="{StaticResource leftStyle}" Content="{m:Loc Name:}" />
      <TextBox Style="{StaticResource rightStyle}" MaxLength="200" Text="{Binding Target.Name, Mode=TwoWay, ValidatesOnExceptions=True}" />
      <Label Grid.Row="1" Style="{StaticResource leftStyle}" Content="{m:Loc Host:}" />
      <TextBox Grid.Row="1" Style="{StaticResource rightStyle}" MaxLength="15" Text="{Binding Target.IpAddress, Mode=TwoWay, ValidatesOnExceptions=True}" />
      <Label Grid.Row="2" Style="{StaticResource leftStyle}" Content="{m:Loc Port:}" />
      <TextBox Grid.Row="2" Style="{StaticResource rightStyle}" MaxLength="5" b:TextBoxNumericBehavior.Mask="Integer" b:TextBoxNumericBehavior.MinimumValue="0" b:TextBoxNumericBehavior.MaximumValue="65535" Text="{Binding Target.Port, Mode=TwoWay, ValidatesOnExceptions=True}" />
    </Grid>
    <DockPanel Grid.Row="1" Margin="0,12,0,0" LastChildFill="False" VerticalAlignment="Bottom">
      <Button Name="button_OK" DockPanel.Dock="Right" b:DialogButtonWorkaround.IsDefault="True" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Content="{m:Loc OK}" Command="{Binding OkCommand}" />
      <Button Name="button_Cancel" DockPanel.Dock="Right" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" IsCancel="True" Margin="0" Content="{m:Loc Cancel}" />
    </DockPanel>
  </Grid>
</ct:CommonDialog>