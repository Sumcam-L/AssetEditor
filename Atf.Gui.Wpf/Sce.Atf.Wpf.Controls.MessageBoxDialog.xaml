<?xml version="1.0" encoding="utf-8"?>
<c:CommonDialog x:Class="Sce.Atf.Wpf.Controls.MessageBoxDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:c="clr-namespace:Sce.Atf.Wpf.Controls" ResizeMode="NoResize" SizeToContent="WidthAndHeight" MaxWidth="500" MinWidth="350" MinHeight="150" ShowInTaskbar="False" WindowStartupLocation="CenterOwner">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <c:Icon x:Name="Image" HorizontalAlignment="Left" VerticalAlignment="Center" Height="48" Width="48" Margin="10,10,0,10" />
    <TextBlock Name="MessageText" Grid.Column="1" TextWrapping="Wrap" TextAlignment="Left" HorizontalAlignment="Left" VerticalAlignment="Top" MinHeight="48" Margin="10" />
    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10,0,10,10">
      <Button Name="OkButton" Content="O_K" IsDefault="True" MinWidth="80" MinHeight="20" Click="OkButton_Click" />
      <Button Name="YesButton" Content="_Yes" MinWidth="80" MinHeight="20" Margin="6,0,0,0" Click="YesButton_Click" />
      <Button Name="NoButton" Content="_No" MinWidth="80" MinHeight="20" Margin="6,0,0,0" Click="NoButton_Click" />
      <Button Name="CancelButton" Content="_Cancel" MinWidth="80" MinHeight="20" Margin="6,0,0,0" Click="CancelButton_Click" />
    </StackPanel>
  </Grid>
</c:CommonDialog>