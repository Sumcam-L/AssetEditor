<?xml version="1.0" encoding="utf-8"?>
<c:CommonDialog x:Class="Sce.Atf.Wpf.Controls.UnhandledExceptionDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:c="clr-namespace:Sce.Atf.Wpf.Controls" xmlns:l="clr-namespace:Sce.Atf.Wpf.Markup" xmlns:b="clr-namespace:Sce.Atf.Wpf" Height="400" Width="500" ShowInTaskbar="False" ResizeMode="CanResize">
  <DockPanel LastChildFill="True">
    <StackPanel Margin="4" DockPanel.Dock="Bottom">
      <DockPanel Margin="4" LastChildFill="False">
        <Button DockPanel.Dock="Right" IsCancel="True" Style="{StaticResource {x:Static b:Resources.DialogButtonStyleKey}}" Content="{l:Loc Quit}" Command="{Binding CancelCommand}" />
        <Button DockPanel.Dock="Right" IsDefault="True" Style="{StaticResource {x:Static b:Resources.DialogButtonStyleKey}}" Content="{l:Loc Continue}" Command="{Binding OkCommand}" />
      </DockPanel>
    </StackPanel>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <TextBox DockPanel.Dock="Top" IsReadOnly="True" MinHeight="40" TextWrapping="Wrap" Text="{Binding Message, Mode=OneTime}" />
    </ScrollViewer>
  </DockPanel>
</c:CommonDialog>