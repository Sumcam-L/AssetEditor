<?xml version="1.0" encoding="utf-8"?>
<ct:CommonDialog x:Class="Sce.Atf.Wpf.Controls.FindTargetsDialog" x:ClassModifier="internal" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:l="clr-namespace:Sce.Atf.Wpf" xmlns:ct="clr-namespace:Sce.Atf.Wpf.Controls" xmlns:c="clr-namespace:Sce.Atf.Wpf.ValueConverters" xmlns:m="clr-namespace:Sce.Atf.Wpf.Markup" xmlns:b="clr-namespace:Sce.Atf.Wpf.Behaviors" ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Width="600" MinWidth="400" Height="300" MinHeight="150" Title="{m:Loc Find Targets}">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="scanButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}">
        <Setter Property="b:ThemeStyleBehavior.AutoMergeStyle" Value="True" />
        <Setter Property="Content" Value="{m:Loc Rescan}" />
        <Style.Triggers>
          <DataTrigger Value="True" Binding="{Binding IsScanning}">
            <Setter Property="Content" Value="{m:Loc Cancel Scan}" />
          </DataTrigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ListView Name="listView" Margin="0,0,0,8" IsSynchronizedWithCurrentItem="True" ItemsSource="{Binding FoundTargets}">
      <ListView.View>
        <GridView>
          <GridViewColumn Width="100" Header="{m:Loc Target}" DisplayMemberBinding="{Binding Target.Name}" />
          <GridViewColumn Width="80" Header="{m:Loc Host}" DisplayMemberBinding="{Binding Target.Host}" />
          <GridViewColumn Width="120" Header="{m:Loc Status}" DisplayMemberBinding="{Binding Target.Status}" />
          <GridViewColumn Width="120" Header="{m:Loc Protocol}" DisplayMemberBinding="{Binding Protocol.Name}" />
          <GridViewColumn Width="100" Header="{m:Loc Info}" DisplayMemberBinding="{Binding Target.ConnectionInfo}" />
        </GridView>
      </ListView.View>
      <ItemsControl.ItemContainerStyle>
        <Style BasedOn="{StaticResource {x:Static GridView.GridViewItemContainerStyleKey}}" TargetType="{x:Type ListViewItem}">
          <Setter Property="b:ThemeStyleBehavior.AutoMergeStyle" Value="True" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="ListBoxItem.IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        </Style>
      </ItemsControl.ItemContainerStyle>
    </ListView>
    <TextBlock FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{m:Loc No Targets Available}" Visibility="{Binding FoundTargets.Count, Converter={c:InverseIntToVisibilityConverter}}" />
    <ProgressBar Grid.Row="1" HorizontalAlignment="Stretch" IsIndeterminate="True" Margin="0,0,0,8" Height="16" Visibility="{Binding IsScanning, Converter={c:BoolToVisibilityConverter}}" />
    <DockPanel Grid.Row="2" LastChildFill="False">
      <Button Style="{StaticResource scanButtonStyle}" Command="{Binding ToggleScanCommand}" />
      <Button Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Content="{m:Loc Add}" Command="{Binding AddFoundTargetCommand}" />
      <Button Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Content="{m:Loc Add All}" Command="{Binding AddAllFoundTargetsCommand}" />
      <Button DockPanel.Dock="Right" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" IsDefault="True" Content="{m:Loc OK}" Command="{Binding OkCommand}" />
    </DockPanel>
  </Grid>
</ct:CommonDialog>