<?xml version="1.0" encoding="utf-8"?>
<Controls:CommonDialog x:Class="Sce.Atf.Wpf.Controls.ProgressDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:l="clr-namespace:Sce.Atf.Wpf" xmlns:c="clr-namespace:Sce.Atf.Wpf.ValueConverters" xmlns:m="clr-namespace:Sce.Atf.Wpf.Markup" xmlns:Controls="clr-namespace:Sce.Atf.Wpf.Controls" WindowStartupLocation="CenterOwner" SizeToContent="Height" Width="400" ResizeMode="NoResize" ShowInTaskbar="False" Title="{Binding Title}">
  <DockPanel Margin="12" LastChildFill="False">
    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" MinHeight="36" TextWrapping="Wrap" Text="{Binding Description}" Visibility="{Binding Cancelled, Converter={c:InverseBoolToVisibilityConverter}}" />
    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" MinHeight="36" TextWrapping="Wrap" Text="{m:Loc Cancelling...}" Visibility="{Binding Cancelled, Converter={c:BoolToVisibilityConverter}}" />
    <ProgressBar DockPanel.Dock="Top" VerticalAlignment="Bottom" Height="23" Value="{Binding Progress, Mode=OneWay}" IsIndeterminate="{Binding IsIndeterminate}" />
    <DockPanel Dock="Bottom" Margin="0,12,0,0" LastChildFill="False">
      <TextBlock Name="lblStatus" DockPanel.Dock="Top" Height="60" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Text="{Binding Content}" />
      <Button DockPanel.Dock="Right" Margin="4,0,0,0" Style="{StaticResource {x:Static l:Resources.DialogButtonStyleKey}}" Visibility="{Binding Cancellable, Converter={c:BoolToVisibilityConverter}}" IsEnabled="{Binding Cancelled, Converter={c:InvertBoolConverter}}" Content="{m:Loc Cancel}" Click="CancelButton_Click" />
    </DockPanel>
  </DockPanel>
</Controls:CommonDialog>