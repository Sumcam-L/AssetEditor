<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Sce.Atf.Wpf.Controls.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:l="clr-namespace:Sce.Atf.Wpf" xmlns:b="clr-namespace:Sce.Atf.Wpf.Behaviors" x:Name="me" Height="600" Width="600" WindowStartupLocation="Manual" AllowDrop="False" Style="{DynamicResource {x:Type Window}}" b:CS4Options.DisplayMode="True" b:CS4Options.UseLayoutRounding="True">
  <DockPanel Name="dockPanel">
    <Menu Name="menuBar" DockPanel.Dock="Top" Style="{StaticResource {x:Static l:Resources.MenuStyleKey}}" ItemsSource="{Binding MainMenuViewModel.Menus, ElementName=me}" />
    <ToolBarTray Name="toolBarTray" DockPanel.Dock="Top" Style="{StaticResource {x:Static l:Resources.ToolBarTrayStyleKey}}" />
    <StatusBar Name="statusBar" DockPanel.Dock="Bottom" MinHeight="16" Style="{StaticResource {x:Static l:Resources.StatusBarStyleKey}}" ItemsSource="{Binding StatusItems, ElementName=me}" />
  </DockPanel>
</Window>