<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:c="clr-namespace:Sce.Atf.Wpf.Controls" xmlns:l="clr-namespace:Sce.Atf.Wpf.Controls.PropertyEditing">
  <DataTemplate x:Key="{x:Static l:MultiLineTextValueEditor.TemplateKey}">
    <TextBox MinHeight="20" AcceptsReturn="True" TextWrapping="NoWrap" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Margin="0" MaxLines="4" Text="{Binding Value, Mode=TwoWay}" IsReadOnly="{Binding IsReadOnly}" />
  </DataTemplate>
  <DataTemplate x:Key="{x:Static l:SliderValueEditor.TemplateKey}">
    <c:SliderBox DeferDragUpdate="True" Value="{Binding EditorContext.DoubleValue, Mode=TwoWay}" IsEnabled="{Binding IsWriteable}" StringFormat="{Binding EditorContext.FormatString, Mode=OneTime}" />
  </DataTemplate>
  <DataTemplate x:Key="{x:Static l:RangeSliderValueEditor.TemplateKey}">
    <c:RangeSlider Minimum="{Binding EditorContext.Min, Mode=OneTime}" Maximum="{Binding EditorContext.Max, Mode=OneTime}" IsEnabled="{Binding IsWriteable}" RangeStop="{Binding EditorContext.RangeStop, Mode=TwoWay}" RangeStart="{Binding EditorContext.RangeStart, Mode=TwoWay}" />
  </DataTemplate>
  <DataTemplate x:Key="{x:Static l:FilePathValueEditor.TemplateKey}">
    <c:FilePicker IsEnabled="{Binding IsWriteable}" FilePath="{Binding EditorContext.Value, ValidatesOnDataErrors=True}" Filter="{Binding EditorContext.Filter}" DefaultExtension="{Binding EditorContext.DefaultExtension}" />
  </DataTemplate>
  <DataTemplate x:Key="{x:Static l:FolderPathValueEditor.TemplateKey}">
    <c:DirectoryPicker Directory="{Binding Value, ValidatesOnDataErrors=True}" IsEnabled="{Binding IsWriteable}" />
  </DataTemplate>
</ResourceDictionary>