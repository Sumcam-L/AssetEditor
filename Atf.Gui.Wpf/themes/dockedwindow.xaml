<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:Sce.Atf.Wpf.Docking" xmlns:vc="clr-namespace:Sce.Atf.Wpf.ValueConverters">
  <vc:BoolVisibilityConverter x:Key="myBoolVisibilityConverter" />
  <vc:NullVisibilityConverter x:Key="myNullVisibilityConverter" />
  <Style x:Key="DockTitleButtonStyle" TargetType="{x:Type ButtonBase}">
    <Setter Property="Foreground" Value="{x:Static SystemColors.ActiveCaptionTextBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ButtonBase}">
          <Border Name="PART_Border" Padding="2" BorderThickness="1" CornerRadius="2" Background="#01ffffff">
            <ContentPresenter />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="PART_Border" Value="{x:Static SystemColors.ControlLightBrush}" Property="Border.Background" />
              <Setter TargetName="PART_Border" Property="Border.BorderBrush" Value="#FF483D8B" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="PART_Border" Property="Border.Background" Value="#FFFEEFE2" />
              <Setter TargetName="PART_Border" Property="Border.BorderBrush" Value="#FF483D8B" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="{x:Type local:DockedWindow}" TargetType="{x:Type local:DockedWindow}">
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="Background" Value="{Binding Path=Background, RelativeSource={RelativeSource AncestorType=local:DockPanel}}" />
    <Setter Property="BorderBrush" Value="#FFA9A9A9" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Panel.ZIndex" Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type local:DockedWindow}">
          <AdornerDecorator SnapsToDevicePixels="True">
            <Border Name="PART_FrameFrame" BorderBrush="#FFC0C0C0">
              <Grid SnapsToDevicePixels="True" Background="#00FFFFFF">
                <Grid.RowDefinitions>
                  <RowDefinition Height="20" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Name="PART_TitleBarBackground" Grid.Row="0" Grid.RowSpan="1" SnapsToDevicePixels="True" Margin="0" Background="#FFD3D3D3">
                  <Border Name="PART_TitleBar" Background="#00FFFFFF">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.RowSpan="1" Grid.Column="0">
                        <Image Margin="2,2,4,0" Width="{Binding Path=Root.HeaderIconSize.Width, RelativeSource={RelativeSource TemplatedParent}}" Height="{Binding Path=Root.HeaderIconSize.Height, RelativeSource={RelativeSource TemplatedParent}}" Source="{Binding Path=DockedContent.Icon, RelativeSource={RelativeSource TemplatedParent}}" Visibility="{Binding Path=ShowIcon, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource myBoolVisibilityConverter}}" />
                        <TextBlock Name="PART_TitleBarText" Foreground="#FF000000" VerticalAlignment="Center" Margin="5,0,0,0" Text="{Binding Path=DockedContent.Header, RelativeSource={RelativeSource TemplatedParent}}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ToggleButton Name="PART_CollapseButton" Margin="1" Height="16" Width="16" Style="{StaticResource DockTitleButtonStyle}">
                          <Path Name="CollapseButtonContent" Data="M0,7 L0,6 L2,6 L2,0 L9,0 L9,6 L11,6 L11,7 L6,7 L6,10 L5,10 L5,7 M3,1 L6,1 L6,6 L3,6" Stretch="Fill" SnapsToDevicePixels="True" Fill="{Binding ElementName=PART_CloseButton, Path=Foreground}">
                            <UIElement.RenderTransformOrigin>
                              <Point X="0.5" Y="0.5" />
                            </UIElement.RenderTransformOrigin>
                          </Path>
                        </ToggleButton>
                        <Button Name="PART_CloseButton" Margin="1" Height="16" Width="16" Style="{StaticResource DockTitleButtonStyle}">
                          <Path Data="M0,0 L9,9 M0,9 L9,0" StrokeThickness="1" Stretch="UniformToFill" Fill="{Binding ElementName=PART_CloseButton, Path=Foreground}" Stroke="{Binding ElementName=PART_CloseButton, Path=Foreground}" />
                        </Button>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Border>
                <Border Background="{TemplateBinding Control.Background}" Grid.Row="1" Grid.RowSpan="1" Margin="0">
                  <ContentPresenter ClipToBounds="True" SnapsToDevicePixels="True" />
                </Border>
              </Grid>
            </Border>
          </AdornerDecorator>
          <ControlTemplate.Triggers>
            <Trigger Property="local:DockedWindow.Focused" Value="True">
              <Setter TargetName="PART_TitleBarBackground" Property="Border.Background" Value="{Binding Background}" />
              <Setter TargetName="PART_FrameFrame" Property="Border.BorderThickness" Value="1" />
              <Setter TargetName="PART_FrameFrame" Property="Margin" Value="-1" />
              <Setter TargetName="PART_TitleBarText" Property="TextBlock.Foreground" Value="#FF000000" />
              <Setter TargetName="PART_CollapseButton" Property="Foreground" Value="#FF000000" />
              <Setter TargetName="PART_CloseButton" Property="Foreground" Value="#FF000000" />
            </Trigger>
            <Trigger SourceName="PART_CollapseButton" Property="ToggleButton.IsChecked" Value="True">
              <Setter TargetName="CollapseButtonContent" Property="RenderTransform">
                <Setter.Value>
                  <RotateTransform Angle="90" />
                </Setter.Value>
              </Setter>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>