<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ct="clr-namespace:Sce.Atf.Wpf.Controls">
  <Style x:Key="{x:Type ct:RangeSlider}" TargetType="{x:Type ct:RangeSlider}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type ct:RangeSlider}">
          <StackPanel Name="PART_RangeSliderContainer" Orientation="Horizontal">
            <RepeatButton Name="PART_LeftEdge" />
            <Thumb Name="PART_LeftThumb" Cursor="SizeWE" />
            <Thumb Name="PART_MiddleThumb" Cursor="ScrollAll" MinWidth="10" />
            <Thumb Name="PART_RightThumb" Cursor="SizeWE" />
            <RepeatButton Name="PART_RightEdge" />
          </StackPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>