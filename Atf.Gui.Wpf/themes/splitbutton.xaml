<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:atf="clr-namespace:Sce.Atf.Wpf.Controls">
  <Style x:Key="{x:Type atf:SplitButton}" TargetType="{x:Type atf:SplitButton}" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="MinWidth" Value="0" />
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Width" Value="36" />
    <Setter Property="Padding" Value="2" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type atf:SplitButton}">
          <Border Name="SplitButtonBorder" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="1">
            <Grid>
              <FrameworkElement.Resources>
                <ResourceDictionary>
                  <Style x:Key="DropDownArrowPath" TargetType="{x:Type Path}">
                    <Setter Property="Data" Value="M0,0 L3,3 L6,0" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="RenderOptions.EdgeMode" Value="Aliased" />
                    <Setter Property="Shape.Stretch" Value="None" />
                  </Style>
                </ResourceDictionary>
              </FrameworkElement.Resources>
              <Grid.RowDefinitions>
                <RowDefinition Height="18" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Name="HighlightBackground" Margin="0,0,-1,0" RenderTransformOrigin="0.5,1" Background="#00FFFFFF" Opacity="0" />
              <atf:Icon x:Name="Icon" ToolTip="{TemplateBinding FrameworkElement.ToolTip}" Margin="{TemplateBinding Control.Padding}" SourceKey="{TemplateBinding atf:Icon.SourceKey}" RedChroma="{TemplateBinding atf:Icon.RedChroma}" GreenChroma="{TemplateBinding atf:Icon.GreenChroma}" BlueChroma="{TemplateBinding atf:Icon.BlueChroma}" />
              <Rectangle Name="SplitLine" Grid.Column="1" Fill="#FF000000" />
              <Border Name="DropDownButtonOver" Grid.Column="2" Margin="-1,0,0,0" Background="#00FFFFFF" Padding="1" ToolTip="{x:Null}">
                <Path Name="DropDownArrow" Margin="3,1,2,0" Fill="#FFFFFFFF" Opacity="0.9" Style="{StaticResource DropDownArrowPath}" />
              </Border>
              <Border Name="PART_DropDownButton" Grid.Column="2" Margin="-1,-1,-1,-1" Background="#00FFFFFF" Padding="1" />
              <Border Name="HighlightBackgroundOver" Margin="-1,-1,-1,-1" Background="#00FFFFFF" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger SourceName="PART_DropDownButton" Property="UIElement.IsMouseOver" Value="True">
              <Setter TargetName="HighlightBackground" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="DropDownButtonOver" Property="UIElement.Opacity" Value="1" />
              <Setter TargetName="DropDownArrow" Property="UIElement.Opacity" Value="1" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="SplitButtonBorder" Property="UIElement.Opacity" Value="0.4" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>