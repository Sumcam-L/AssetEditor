<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:l="clr-namespace:Sce.Atf.Wpf.Controls.PropertyEditing" xmlns:c="clr-namespace:Sce.Atf.Wpf.Controls" xmlns:vc="clr-namespace:Sce.Atf.Wpf.ValueConverters" xmlns:m="clr-namespace:Sce.Atf.Wpf.Markup">
  <Style x:Key="{x:Type l:PropertyGridToolBar}" TargetType="{x:Type l:PropertyGridToolBar}">
    <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type l:PropertyGridToolBar}">
          <Border BorderThickness="{TemplateBinding Control.BorderThickness}" BorderBrush="{TemplateBinding Control.BorderBrush}" Background="{TemplateBinding Control.Background}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" Padding="{TemplateBinding Control.Padding}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Button Command="{x:Static l:PropertyGridToolBar.ShowCategorized}" Width="16" Height="16" MinWidth="16" ToolTip="{m:Loc Sort by Category}">
                <Path Data="M0,0 L5,0 L5,1 L0,1 M7,0 L12,0 L12,1 L7,1 M7,2 L12,2 L12,3 L7,3 M0,4 L5,4 L5,5 L0,5 M7,4 L12,4 L12,5 L7,5 M7,6 L12,6 L12,7 L7,7" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="True" />
              </Button>
              <Button Command="{x:Static l:PropertyGridToolBar.ShowAlphaSorted}" Width="16" Height="16" MinWidth="16" ToolTip="Sort Alphabetically">
                <Path Data="M2,0 L4,0 L4,5 L6,5 L3,8 L0,5 L2,5" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="True" />
              </Button>
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>