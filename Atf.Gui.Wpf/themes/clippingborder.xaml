<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:gac="clr-namespace:Sce.Atf.Wpf.Controls">
  <Style x:Key="{x:Type gac:ClippingBorder}" TargetType="{x:Type gac:ClippingBorder}">
    <Setter Property="gac:ClippingBorder.ClipContent" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type gac:ClippingBorder}">
          <Border Name="PART_Border" Background="{TemplateBinding Control.Background}" CornerRadius="{TemplateBinding gac:ClippingBorder.CornerRadius}" BorderThickness="{TemplateBinding Control.BorderThickness}" BorderBrush="{TemplateBinding Control.BorderBrush}">
            <Grid>
              <ContentControl Name="PART_TopLeftContentControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <UIElement.Clip>
                  <RectangleGeometry x:Name="PART_TopLeftClip" />
                </UIElement.Clip>
                <ContentControl Name="PART_TopRightContentControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                  <UIElement.Clip>
                    <RectangleGeometry x:Name="PART_TopRightClip" />
                  </UIElement.Clip>
                  <ContentControl Name="PART_BottomRightContentControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <UIElement.Clip>
                      <RectangleGeometry x:Name="PART_BottomRightClip" />
                    </UIElement.Clip>
                    <ContentControl Name="PART_BottomLeftContentControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                      <UIElement.Clip>
                        <RectangleGeometry x:Name="PART_BottomLeftClip" />
                      </UIElement.Clip>
                      <ContentPresenter Margin="{TemplateBinding Control.Padding}" />
                    </ContentControl>
                  </ContentControl>
                </ContentControl>
              </ContentControl>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>