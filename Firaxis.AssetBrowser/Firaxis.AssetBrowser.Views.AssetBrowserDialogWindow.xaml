<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Firaxis.AssetBrowser.Views.AssetBrowserDialogWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mvvma="clr-namespace:Firaxis.MVVMBase.Attached;assembly=Firaxis.MVVMBase" xmlns:aba="clr-namespace:Firaxis.AssetBrowser.Attached" Title="Asset Browser" ShowInTaskbar="False" Topmost="False" MinHeight="354" MinWidth="576" Height="480" Width="800" aba:SkinServiceHelper.ApplySkin="True" mvvma:GlobalPropertyCache.Location="True" mvvma:GlobalPropertyCache.Size="True" xmlns:views="clr-namespace:Firaxis.AssetBrowser.Views" mvvma:WindowHelper.RequestedClose="{Binding RequestedClose}" mvvma:WindowHelper.DialogResult="{Binding DialogResult}">
  <UIElement.InputBindings>
    <KeyBinding Key="Enter" Command="{Binding AcceptCommand}" />
  </UIElement.InputBindings>
  <Grid Margin="5">
    <ContentPresenter Name="ctlAssetBrowser" Margin="0,0,0,48" MinHeight="276" MinWidth="568" Content="{Binding AssetBrowser}" />
    <Button Name="btnCancel" IsCancel="True" Content="Cancel" Margin="0,0,10,12" HorizontalAlignment="Right" Width="75" Height="22" VerticalAlignment="Bottom" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Command="{Binding CancelCommand}" />
    <Button Name="btnOK" IsDefault="True" Content="OK" Margin="0,0,95,12" Height="22" Width="75" VerticalAlignment="Bottom" HorizontalAlignment="Right" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Command="{Binding AcceptCommand}" />
  </Grid>
</Window>