    <ProjectReference Include="..\Firaxis.AssetEditing\Firaxis.AssetEditing.csproj" />
    <ProjectReference Include="..\Firaxis.Controls\Firaxis.Controls.csproj" />
    <ProjectReference Include="..\Firaxis.VersionControl\Firaxis.VersionControl.csproj" />
    <ProjectReference Include="..\Firaxis.Theme\Firaxis.Theme.csproj" />
    <ProjectReference Include="..\Firaxis.Utility\Firaxis.Utility.csproj" />
    <ProjectReference Include="..\Firaxis.Error\Firaxis.Error.csproj" />
    <ProjectReference Include="..\Firaxis.AssetBrowser\Firaxis.AssetBrowser.csproj" />
    <ProjectReference Include="..\Firaxis.MVVMBase\Firaxis.MVVMBase.csproj" />
    <ProjectReference Include="..\Atf.IronPython\Atf.IronPython.csproj" />
